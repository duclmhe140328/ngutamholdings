# Để /api khi chạy localhost hoặc dùng 1 tunnel ngrok vào cổng 5173.
VITE_API_URL=/api

# Để trống để Socket.IO dùng cùng domain đang mở (localhost/ngrok/domain thật).
VITE_SOCKET_URL=

# Không bắt buộc. Có thể đặt domain công khai mặc định dùng để sinh QR.
# Ví dụ: https://abc123.ngrok-free.app
VITE_PUBLIC_APP_URL=
