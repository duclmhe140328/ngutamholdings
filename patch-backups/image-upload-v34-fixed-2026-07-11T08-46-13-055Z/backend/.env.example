PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/multi_shop_saas
JWT_SECRET=thay_bang_chuoi_bi_mat_dai

# Chỉ cần khi frontend và backend chạy khác domain.
# Có thể nhập nhiều domain, phân tách bằng dấu phẩy.
CLIENT_URLS=http://localhost:5173

ADMIN_NAME=Admin Tổng
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=123456
ADMIN_PHONE=0900000000

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ZALO_WEBHOOK_URL=

VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Production phải đổi thành domain thật, ví dụ:
# https://ten-web.onrender.com/api/payments/vnpay-return
VNP_RETURN_URL=http://localhost:5000/api/payments/vnpay-return

# Xác thực số điện thoại cho ví xu / vòng quay
# Local: OTP_DEV_MODE=true và OTP_DEV_CODE=123456
# Production: đặt OTP_DEV_MODE=false và cung cấp webhook SMS thật.
OTP_DEV_MODE=true
OTP_DEV_CODE=123456
OTP_HASH_SECRET=doi-chuoi-hash-otp
LOYALTY_JWT_SECRET=doi-chuoi-ky-vi-xu
SMS_OTP_WEBHOOK_URL=
SMS_OTP_WEBHOOK_TOKEN=

# Tùy chọn: endpoint OSRM tương thích để lấy km đường bộ thật. Nếu trống sẽ dùng khoảng cách ước tính.
ROUTING_API_URL=

# Phiên bàn: giữ đúng khách/bàn/hóa đơn khi thoát rồi quay lại.
DINING_SESSION_SECRET=doi-chuoi-bi-mat-phien-ban

# Web Push nền cho PWA. Tạo bằng: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
DINING_SESSION_MAX_HOURS=12

# SePay tự động xác nhận chuyển khoản QR.
# Có thể dùng một API key chung cho toàn hệ thống hoặc nhập API key riêng trong Dashboard từng shop.
SEPAY_WEBHOOK_API_KEY=

# FORGOT_PASSWORD_V33
# Quên mật khẩu dùng chung nhà cung cấp SMS OTP hiện tại.
# SMS_OTP_WEBHOOK_URL=https://...
# SMS_OTP_WEBHOOK_TOKEN=...
# OTP_DEV_MODE=true chỉ dùng local/test; production phải để false.
